# ANTON Backend — Environment Variables
# -----------------------------------------------
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to git.
# -----------------------------------------------

# Groq API key for LLaMA 3 AI summaries
# Get yours free at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here


# JWT signing secret — generate with: openssl rand -hex 32
SECRET_KEY=your_random_secret_key_here_change_this_in_production

# Admin panel access key (sent as X-Admin-Key header)
ADMIN_KEY=your_admin_secret_key_here

# Database URL (defaults to SQLite for local dev)
# For PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./anton.db
